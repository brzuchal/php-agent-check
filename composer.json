{
    "name": "brzuchal/php-agent-check",
    "description": "Unified, machine-oriented validation runner for PHP projects",
    "type": "project",
    "require": {
        "php": "^8.1",
        "symfony/console": "^6.0 || ^7.0",
        "symfony/process": "^6.0 || ^7.0",
        "symfony/yaml": "^6.0 || ^7.0",
        "symfony/config": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Brzuchal\\PhpAgentCheck\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brzuchal\\PhpAgentCheck\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/agentchk"
    ],
    "scripts": {
        "verify": "bin/agentchk --profile=full --mode=human",
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "platform": {
            "php": "8.1.99"
        }
    }
}

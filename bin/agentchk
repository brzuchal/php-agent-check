#!/usr/bin/env php
<?php

$files = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../../autoload.php',
    __DIR__ . '/vendor/autoload.php',
];
$autoloadResult = false;
foreach ($files as $file) {
    if (file_exists($file)) {
        require $file;
        $autoloadResult = true;
        break;
    }
}
if (!$autoloadResult) {
    die("You must set up the project dependencies, run the following commands:\n> wget https://getcomposer.org/composer.phar\n> php composer.phar install\n");
}

use Symfony\Component\Console\Application;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Console\Output\ConsoleOutput;
use Brzuchal\PhpAgentCheck\Command\CheckCommand;
use Brzuchal\PhpAgentCheck\Command\InitCommand;
use Brzuchal\PhpAgentCheck\Service\AgentCheck;
use Brzuchal\PhpAgentCheck\Infrastructure\Config\YamlConfigurationLoader;
use Brzuchal\PhpAgentCheck\Infrastructure\Process\SymfonyProcessRunner;
use Brzuchal\PhpAgentCheck\Infrastructure\Reporter\JsonReportWriter;
use Brzuchal\PhpAgentCheck\Infrastructure\Reporter\HumanReportWriter;
use Brzuchal\PhpAgentCheck\Tool\PhpUnit\PhpUnitCheck;
use Brzuchal\PhpAgentCheck\Tool\PhpUnit\PhpUnitJunitParser;
use Brzuchal\PhpAgentCheck\Tool\PhpUnit\PhpUnitDetector;
use Brzuchal\PhpAgentCheck\Tool\PhpStan\PhpStanCheck;
use Brzuchal\PhpAgentCheck\Tool\PhpStan\PhpStanJsonParser;
use Brzuchal\PhpAgentCheck\Tool\PhpStan\PhpStanDetector;
use Brzuchal\PhpAgentCheck\Tool\PhpCs\PhpCsCheck;
use Brzuchal\PhpAgentCheck\Tool\PhpCs\PhpCsJsonParser;
use Brzuchal\PhpAgentCheck\Tool\PhpCs\PhpCsDetector;
use Brzuchal\PhpAgentCheck\Domain\ExecutionMode;

$input = new ArgvInput();
$output = new ConsoleOutput();

$format = $input->getParameterOption(['--format', '-f']) ?: (getenv('AGENTCHK_OUTPUT') === 'json' ? 'json' : null);
$modeOpt = $input->getParameterOption(['--mode', '-m']) ?: 'human';
$envMode = getenv('AGENTCHK_MODE');
if ($envMode !== false) {
    $modeOpt = $envMode === '1' ? 'agent' : $envMode;
} elseif (getenv('AGENT_MODE') === '1') {
    $modeOpt = 'agent';
}

$mode = ExecutionMode::tryFrom($modeOpt) ?? ExecutionMode::Human;

if ($format === 'json' || $mode === ExecutionMode::Agent) {
    $reporters = [new JsonReportWriter($output)];
} else {
    $reporters = [new HumanReportWriter($output)];
}

$checks = [
    new PhpUnitCheck(new PhpUnitJunitParser()),
    new PhpStanCheck(new PhpStanJsonParser()),
    new PhpCsCheck(new PhpCsJsonParser()),
];

$detectors = [
    new PhpUnitDetector(),
    new PhpStanDetector(),
    new PhpCsDetector(),
];

$agentCheck = new AgentCheck(
    new YamlConfigurationLoader(),
    new SymfonyProcessRunner($output),
    $checks,
    $reporters
);

$application = new Application('AgentCheck', '0.1.0');
$application->add(new CheckCommand($agentCheck));
$application->add(new InitCommand($detectors));
$application->setDefaultCommand('check', false);
$application->run($input, $output);
